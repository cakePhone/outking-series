# Required
ORIGIN=http://localhost:5173
DATABASE_URL=local.db
BETTER_AUTH_SECRET=

# Discord OAuth (for login)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Discord guild integration (for role display)
# Get the guild ID from Discord: right-click server icon → Copy Server ID
DISCORD_GUILD_ID=
# Bot token for fetching guild roles. Create a bot at https://discord.com/developers/applications
DISCORD_BOT_TOKEN=
# Invite link for users to join the OutKing server
DISCORD_INVITE_URL=
# Guild ID for admin dashboard access (company/org server)
ADMIN_GUILD_ID=

# Riot Games API KEY
RG_API_KEY=
